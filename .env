# =============================================================================
# APPMAX FRONTEND ENV (.env)
# =============================================================================
# Este arquivo concentra TODAS as configurações de integração usadas no frontend.
# IMPORTANTE:
# - Qualquer variável com prefixo VITE_ será embutida no bundle e visível no browser.
# - Portanto, segredos reais de produção devem ir para um backend server-side.
# =============================================================================

# -----------------------------------------------------------------------------
# SUPABASE (frontend public config)
# -----------------------------------------------------------------------------
# URL do projeto Supabase.
VITE_SUPABASE_URL="https://lwusznsduxcqjjmbbobt.supabase.co"

# ID curto do projeto Supabase (opcional no frontend; útil para referência).
VITE_SUPABASE_PROJECT_ID="lwusznsduxcqjjmbbobt"

# Chave ANON (publicável) do Supabase.
# Não use service role no frontend.
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_c0yDYJ79ltCXMGznHYyOQQ_Y2zjyhtY"

# -----------------------------------------------------------------------------
# GOOGLE SSO (frontend OAuth)
# -----------------------------------------------------------------------------
# Client ID OAuth Web App.
VITE_GOOGLE_CLIENT_ID="19779916042-ur7fs5qdorm32bsen7vtfcurkoka4sp7.apps.googleusercontent.com"

# Domínio permitido para login.
VITE_GOOGLE_ALLOWED_DOMAIN="appmax.com.br"

# URI de callback (deve bater 100% com o Google Cloud Console).
VITE_GOOGLE_REDIRECT_URI="http://localhost:8080/auth/google/callback"

# -----------------------------------------------------------------------------
# OPENAI TOKENS (usados no frontend atual)
# -----------------------------------------------------------------------------
# ATENÇÃO: enquanto estiverem em VITE_*, ficam expostos no bundle.
# Recomendação de produção: mover para backend/BFF.
VITE_OPENAI_TOKEN_MEETINGS=""
VITE_OPENAI_TOKEN_TRAINING=""
VITE_OPENAI_TOKEN_WHATSAPP=""
VITE_OPENAI_TOKEN_REPORTS=""
VITE_OPENAI_TOKEN_AUTOMATIONS=""

# -----------------------------------------------------------------------------
# EVOLUTION API (WhatsApp)
# -----------------------------------------------------------------------------
# URL base da Evolution API (sem barra final).
VITE_EVOLUTION_API_URL=""

# Token de autenticação da Evolution API.
# Recomendação de produção: backend proxy para não expor token no browser.
VITE_EVOLUTION_API_TOKEN=""

# -----------------------------------------------------------------------------
# SERVER-SIDE ONLY (NÃO usado pelo frontend)
# -----------------------------------------------------------------------------
# Estas variáveis NÃO têm prefixo VITE_.
